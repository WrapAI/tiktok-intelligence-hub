{
  "name": "tiktok-intelligence-hub",
  "version": "0.1.0",
  "description": "Desktop hub for TikTok Hook Analyzer — library, performance, predictions, and script writing",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.node.json && vite build",
    "preview": "vite preview",
    "start": "electron .",
    "data:export": "node scripts/data-sync.mjs export",
    "data:export:force": "node scripts/data-sync.mjs export --force",
    "data:import": "node scripts/data-sync.mjs import",
    "data:push": "node scripts/data-sync.mjs export --force && git add data/ && git status --short data/"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "googleapis": "^173.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "uuid": "^11.0.5",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^6.0.2",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "typescript": "^5.7.3",
    "vite": "^8.0.16",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "com.wrapai.tiktok-intelligence-hub",
    "productName": "TikTok Intelligence Hub",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ]
  }
}
