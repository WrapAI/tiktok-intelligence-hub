{
  "name": "tiktok-intelligence-hub",
  "version": "0.1.0",
  "description": "Desktop hub for TikTok Hook Analyzer — library, performance, predictions, and script writing",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.node.json && vite build",
    "dist": "npm run build && electron-builder --win --x64",
    "ensure-electron": "node node_modules/electron/install.js",
    "preview": "vite preview",
    "start": "electron .",
    "data:export": "node scripts/data-sync.mjs export",
    "data:import": "node scripts/data-sync.mjs import"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "googleapis": "^173.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "uuid": "^11.0.5",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "com.wrapai.tiktok-intelligence-hub",
    "productName": "TikTok Intelligence Hub",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "TikTok Intelligence Hub"
    }
  }
}
